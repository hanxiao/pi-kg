# pi-kg configuration (copy to .env or export in shell)
LLAMA_URL=http://YOUR_L4_IP:8080          # Qwen3.6-35B-A3B-MTP server (see github.com/hanxiao/Qwen3.6-35B-A3B-MTP-L4)
MODEL_ID=qwen3.6
CONTEXT_WINDOW=56320                       # MUST match the server's --ctx-size (L4 default 56320)
EMBED_MODEL=jinaai/jina-embeddings-v5-text-small
EMBED_BACKEND=local                        # local | api  (api needs JINA_API_KEY)
RERANK_BACKEND=local
# JINA_API_KEY=jina_xxx                     # only if EMBED_BACKEND/RERANK_BACKEND=api
THINKING_LEVEL=high                        # thinking is ON by default
PROMPT_VARIANT=steps                       # steps | outcome  (the A/B test axis)
KGBOX_TOOLS=embed_texts,similarity,cluster,select_diverse,rerank
TURN_BUDGET=12
COMPACTION_RESERVE_TOKENS=20000
COMPACTION_KEEP_RECENT_TOKENS=8000
